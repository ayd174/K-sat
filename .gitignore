node_modules/
temporary screenshots/
.claude/
*.log

# Master environment — Single Source of Truth (never commit)
.env
.env.*
!.env.example

# Workflow JSON exports — contain API secrets, never commit
# Glob (not directory) so specific files can be re-included below.
workflows/*

# Independent sub-projects with their own git repos and deploy pipelines
Dashboard_SaaS/
Driver_app/
Workshop_app/

# Operational tooling — n8n workflow snapshots + push scripts (credentials inside)
# Glob pattern (not directory) so specific files can be re-included below.
PROMPT lar/_workflow_backups/*

# Root-level operational backups — DB snapshots, recovery lists, customer PII
/_workflow_backups/
workflows/_workflow_backups/

# Operational dumps, scratch & audit dirs — hold live n8n state / service_role
# JWT / exec data. Never commit (P0 secret-leak fix 2026-06-08).
_wf_dump.json
*_wf_dump*.json
_tmp/
_audit_*/
_baseline_tmp/
_uat_transcripts/
_snapshot_*.json
cj1_deployed.js
sdo.js
# vapi_optimizer n8n exports / proposed configs — embed live service_role JWT
vapi_optimizer/workflows/
vapi_optimizer/proposed_*.json

# Apply/protect/smoke python scripts + spec — embed live DB password, VAPI private
# key, n8n public-API JWT & service_role JWT in cleartext. Never commit (P0 2026-06-14).
vapi_optimizer/_*.py
vapi_optimizer/SELF_LEARNING_SPEC.md
supabase_migrations/_*.py

# Exceptions: source-bound build tooling (no credentials, no PII).
# Must come AFTER directory-level rules above; parent dir is not excluded
# (only its contents via glob), enabling re-inclusion.
!PROMPT lar/_workflow_backups/build.py
!PROMPT lar/_workflow_backups/whitelist_constants.py
!workflows/ROUTES PLANNING.json
